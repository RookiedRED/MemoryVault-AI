# MemoryVault AI — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── OpenAI (cloud Expert Model) ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048

# ── Ollama (local Guardian Model) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=30

# ── Retrieval tuning ───────────────────────────────────────────────────────
# Cosine distance threshold — chunks above this score are dropped as irrelevant.
# Range 0–2; lower = stricter. Default 0.50 filters out unrelated vault content.
RETRIEVAL_DISTANCE_THRESHOLD=0.50
RETRIEVAL_TOP_K=3

# Max characters of local context sent to the cloud in a single prompt.
EXPERT_MAX_CONTEXT_CHARS=4000

# ── Database ───────────────────────────────────────────────────────────────
# DB_PATH=memoryvault.db

# ── Server ─────────────────────────────────────────────────────────────────
# HOST=127.0.0.1
# PORT=8000
